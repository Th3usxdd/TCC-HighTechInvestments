<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>InvesTech | Plataforma de Investimentos & Freelas</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body class="bg-gray-900 text-gray-100 font-sans min-h-screen">

    <nav class="bg-gray-800 border-b border-gray-700 sticky top-0 z-50">
        <div class="max-w-7xl px-4 sm:px-6 lg:px-8">
            <div class="flex items-center justify-between h-16">
                <div class="flex items-center gap-2">
                    <i class="fa-solid fa-chart-line text-emerald-400 text-2xl"></i>
                    <span class="text-xl font-bold tracking-wider bg-gradient-to-r from-emerald-400 to-cyan-400 bg-clip-text text-transparent">InvesTech</span>
                </div>
                <div class="flex items-center gap-6">
                    <div class="text-right">
                        <p class="text-xs text-gray-400">Saldo Disponível</p>
                        <p id="balance-display" class="text-lg font-bold text-emerald-400">R$ 10.000,00</p>
                    </div>
                </div>
            </div>
        </div>
    </nav>

    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
        
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
            <div class="bg-gray-800 p-6 rounded-xl border border-gray-700 shadow-lg">
                <div class="flex justify-between items-center mb-2">
                    <span class="text-gray-400 font-medium">Patrimônio em Ativos</span>
                    <i class="fa-solid fa-wallet text-cyan-400"></i>
                </div>
                <p id="assets-display" class="text-2xl font-bold text-gray-100">R$ 0,00</p>
            </div>
            <div class="bg-gray-800 p-6 rounded-xl border border-gray-700 shadow-lg">
                <div class="flex justify-between items-center mb-2">
                    <span class="text-gray-400 font-medium">Renda Fixa (CDB/CDI)</span>
                    <i class="fa-solid fa-piggy-bank text-purple-400"></i>
                </div>
                <p id="fixed-income-display" class="text-2xl font-bold text-purple-400">R$ 0,00</p>
                <p class="text-xs text-gray-500 mt-1">*Rende +0.01% a cada 5 segundos (Simulação)</p>
            </div>
            <div class="bg-gray-800 p-6 rounded-xl border border-gray-700 shadow-lg">
                <div class="flex justify-between items-center mb-2">
                    <span class="text-gray-400 font-medium">Ganhos com Freela</span>
                    <i class="fa-solid fa-laptop-code text-amber-400"></i>
                </div>
                <p id="freela-display" class="text-2xl font-bold text-amber-400">R$ 0,00</p>
            </div>
        </div>

        <div class="flex border-b border-gray-700 mb-6 gap-4">
            <button onclick="switchTab('investments')" id="tab-investments" class="py-2 px-4 border-b-2 border-emerald-400 text-emerald-400 font-medium transition-all cursor-pointer">Mercado (Ações & Cripto)</button>
            <button onclick="switchTab('fixed')" id="tab-fixed" class="py-2 px-4 border-b-2 border-transparent text-gray-400 hover:text-gray-200 font-medium transition-all cursor-pointer">Renda Fixa</button>
            <button onclick="switchTab('freela')" id="tab-freela" class="py-2 px-4 border-b-2 border-transparent text-gray-400 hover:text-gray-200 font-medium transition-all cursor-pointer">Painel Freelancer</button>
        </div>

        <section id="sec-investments" class="space-y-6">
            <div class="bg-gray-800 rounded-xl border border-gray-700 p-6">
                <h2 class="text-xl font-bold mb-4 flex items-center gap-2">
                    <i class="fa-solid fa-store text-emerald-400"></i> Home Broker Simulado
                </h2>
                <div class="overflow-x-auto">
                    <table class="w-full text-left">
                        <thead>
                            <tr class="text-gray-400 border-b border-gray-700 text-sm">
                                <th class="pb-3">Ativo</th>
                                <th class="pb-3">Tipo</th>
                                <th class="pb-3">Preço Atual</th>
                                <th class="pb-3">Sua Qtd</th>
                                <th class="pb-3 text-right">Ações</th>
                            </tr>
                        </thead>
                        <tbody id="market-table" class="divide-y divide-gray-700/50">
                            </tbody>
                    </table>
                </div>
            </div>
        </section>

        <section id="sec-fixed" class="hidden space-y-6">
            <div class="bg-gray-800 rounded-xl border border-gray-700 p-6">
                <h2 class="text-xl font-bold mb-4 text-purple-400"><i class="fa-solid fa-vault mr-2"></i>Contratar Renda Fixa</h2>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div class="bg-gray-900/50 p-5 rounded-lg border border-gray-700">
                        <h3 class="font-bold text-lg text-gray-200">CDB Banco InvesTech 110% CDI</h3>
                        <p class="text-sm text-gray-400 mt-1">Liquidez diária, simulado em tempo real.</p>
                        <div class="mt-4 flex gap-2">
                            <input type="number" id="cdb-amount" placeholder="Valor em R$" class="bg-gray-800 border border-gray-600 rounded px-3 py-2 text-sm focus:outline-none focus:border-purple-400 w-full">
                            <button onclick="investFixedIncome()" class="bg-purple-600 hover:bg-purple-500 text-white font-medium px-4 py-2 rounded text-sm transition-all whitespace-nowrap cursor-pointer">Investir</button>
                        </div>
                    </div>
                    <div class="bg-gray-900/50 p-5 rounded-lg border border-gray-700 flex flex-col justify-between">
                        <div>
                            <h3 class="font-bold text-lg text-gray-200">Resgatar Renda Fixa</h3>
                            <p class="text-sm text-gray-400 mt-1">Ret
                                <style>
                                    /* Animação para quando o saldo aumentar (Verde Flash) */
                                    .money-grow {
                                        animation: flashGreen 0.8s ease-out;
                                    }
                                    
                                    /* Animação para quando o saldo diminuir (Vermelho Flash) */
                                    .money-shrink {
                                        animation: flashRed 0.8s ease-out;
                                    }
                                
                                    /* Efeito de pulso sutil para o rendimento do CDB */
                                    .interest-pulse {
                                        animation: pulsePurple 1.5s ease-in-out infinite alternate;
                                    }
                                
                                    /* Keyframes */
                                    @keyframes flashGreen {
                                        0% { color: #10b981; transform: scale(1.08); }
                                        100% { transform: scale(1); }
                                    }
                                
                                    @keyframes flashRed {
                                        0% { color: #ef4444; transform: scale(1.08); }
                                        100% { transform: scale(1); }
                                    }
                                
                                    @keyframes pulsePurple {
                                        0% { box-shadow: 0 0 0 0 rgba(168, 85, 247, 0.4); }
                                        100% { box-shadow: 0 0 15px 4px rgba(168, 85, 247, 0.2); }
                                    }
                                
                                    /* Transição suave para mudança de abas */
                                    .tab-content {
                                        transition: opacity 0.25s ease-in-out, transform 0.25s ease-in-out;
                                    }
                                    .tab-hidden {
                                        opacity: 0;
                                        transform: translateY(10px);
                                        pointer-events: none;
                                        position: absolute;
                                        width: 100%;
                                    }
